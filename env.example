# PostHog Analytics
# Get your project token from https://us.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=your_posthog_project_token
# Optional alias supported by some PostHog guides/integrations
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# Database
MONGODB_URI=mongodb://localhost:27017/portfolio-blog

# Clerk Authentication (optional in development)
# Leave the placeholder values below to run `npm run dev` without auth.
# When ready, replace with real keys from https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/signatures
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/signatures

# Cal.com Integration
CALCOM_API_KEY=your_calcom_api_key
CALCOM_BASE_URL=https://your-calcom-instance.com
NEXT_PUBLIC_CALCOM_BASE_URL=https://your-calcom-instance.com

# GitHub API
GITHUB_TOKEN=your_github_personal_access_token

# Mux Video Streaming
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_SECRET=your_mux_webhook_secret

# Site URL for CORS and webhooks
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Blob Storage for Photos
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# Tabreeze Feedback (Resend + Upstash)
TABREEZE_FEEDBACK_TO_EMAIL=your_email@example.com
# Must be a verified sender/domain in Resend
TABREEZE_FEEDBACK_FROM_EMAIL=feedback@yourdomain.com
RESEND_API_KEY=your_resend_api_key
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
# Comma-separated exact origins (localhost:3000 is allowed automatically in development)
TABREEZE_FEEDBACK_ALLOWED_ORIGINS=chrome-extension://your-extension-id,http://localhost:5173
